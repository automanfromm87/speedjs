; Embed tools/trace_viewer.html as an OCaml string literal so
; Trace.write_html_report can splice ndjson into it without depending
; on the file being installed alongside the binary.
;
; Re-runs whenever tools/trace_viewer.html changes. The OCaml quoted
; string {speedjs_viewer|...|speedjs_viewer} accepts arbitrary content
; verbatim — the only forbidden subsequence is "|speedjs_viewer}",
; which the viewer never contains.
(rule
 (target trace_viewer_template.ml)
 (deps (file ../../tools/trace_viewer.html))
 (action
  (with-stdout-to %{target}
   (bash
    "echo '(* AUTO-GENERATED from tools/trace_viewer.html. Edit the html, not this file. *)'; \
     echo 'let html : string = {speedjs_viewer|'; \
     cat %{deps}; \
     echo '|speedjs_viewer}'"))))
