# speedjs local env overrides (committed as a template).
#
# Copy to .env.local (gitignored) and fill in for your environment.
# dev.sh / continue.sh source .env.local automatically when present.
#
# Public defaults talk to api.anthropic.com directly. Set these to route
# through a gateway / corporate proxy / internal LLM service.

# Required when going to api.anthropic.com directly. Leave unset (or set to
# a placeholder like "not-needed") when going through a gateway that
# injects auth on its own.
# export ANTHROPIC_API_KEY="sk-ant-..."

# Override the API base URL (e.g. an internal LLM gateway).
# export AGENT_LLM_BASE_URL="https://your-gateway.example.com"

# Outbound HTTP proxy host:port (used as curl -x argument). Leave unset
# for direct connections.
# export AGENT_LLM_PROXY="localhost:10054"

# Optional: extra headers to attach to every request. Newline-separated.
# export ANTHROPIC_CUSTOM_HEADERS="X-Foo: bar"

# Optional: override the default model.
# export SPEEDJS_MODEL="claude-sonnet-4-5-20250929"
